# Backend config
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8787

# CORS (comma-separated). Use "*" only for development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DB_URL=sqlite:///./copaw.db

# Auth
AUTH_DISABLED=true
JWT_SECRET=dev-secret-change-me
JWT_TTL_SECONDS=86400
ALLOW_REGISTER=true

# Bootstrap admin (created/updated at startup if set)
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Provider selection (currently: openai_compat)
PROVIDER=openai_compat

# OpenAI-compatible provider settings (works with many gateways, including Qwen OpenAI-compat endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4.1-mini

# Preset model profiles (only when this user has zero profiles, on first GET /api/models/profiles):
# 1) OpenAI: if OPENAI_API_KEY is set — seeds several OpenAI-compatible entries.
#    Override list: COPAW_PRESET_MODELS=gpt-4.1-mini,gpt-4o-mini,gpt-4o
# 2) Ollama: tries GET {OLLAMA_BASE_URL}/api/tags and creates one profile per installed model.
#    If Ollama is unreachable, backend falls back to COPAW_OLLAMA_PRESET_MODELS (default: llama3.1).
OLLAMA_BASE_URL=http://127.0.0.1:11434
COPAW_OLLAMA_PRESET_MODELS=llama3.1
#
# Runtime overrides (OpenAI key, URLs, preset lists) can also be edited in the web UI:
# 齿轮菜单 → 「连接与模型设置」（管理员，或 AUTH_DISABLED=true 时任意已登录用户）

